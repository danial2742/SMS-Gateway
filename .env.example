# Local-dev-only convenience (docs/deployment.md Secrets management — never
# the pattern for a shared/production environment). Copy to .env before
# `docker compose up`.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sms_gateway
DATABASE_READ_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sms_gateway

REDIS_URL=redis://redis:6379/0

KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_EXPRESS=sms.express
KAFKA_TOPIC_NORMAL=sms.normal
KAFKA_TOPIC_DLQ_EXPRESS=sms.dlq.express
KAFKA_TOPIC_DLQ_NORMAL=sms.dlq.normal

# "mock" (default, no external dependency) or "http" against a real endpoint.
OPERATOR_MODE=mock
OPERATOR_API_URL=http://operator-mock:9100
OPERATOR_API_TIMEOUT_MS=5000

IDEMPOTENCY_KEY_TTL_SECONDS=30
RATE_LIMIT_RPS=500
REPORT_MAX_RANGE_DAYS=90
BATCH_MAX_RECIPIENTS=50000

LOG_LEVEL=info
SHUTDOWN_GRACE_PERIOD_SECONDS=30
METRICS_PORT=9000
HEALTH_PORT=8081
